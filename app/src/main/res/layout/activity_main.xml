<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#080B12">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tradutor"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <ImageButton
            android:id="@+id/btn_swap"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="@android:color/transparent"
            android:tint="#FFFFFF"/>
    </LinearLayout>

    <!-- Cards de tradução -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_left"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:layout_margin="8dp"
        android:clickable="true"
        android:focusable="true"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="#12122A"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_left_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🎧 Português"
                    android:textColor="#6C6CFF"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

                <View
                    android:id="@+id/indicator_left"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="#6C6CFF"
                    android:visibility="invisible"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_left"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:text="aguardando..."
                android:textColor="#CCCCCC"
                android:textSize="16sp"
                android:gravity="center"
                android:layout_marginTop="8dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/card_right"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:layout_margin="8dp"
        android:clickable="true"
        android:focusable="true"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="#0F1A12"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_right_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🎧 Inglês"
                    android:textColor="#4CAF50"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

                <View
                    android:id="@+id/indicator_right"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="#4CAF50"
                    android:visibility="invisible"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_right"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:text="aguardando..."
                android:textColor="#CCCCCC"
                android:textSize="16sp"
                android:gravity="center"
                android:layout_marginTop="8dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Histórico -->
    <ScrollView
        android:id="@+id/history_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3"
        android:layout_marginHorizontal="8dp"
        android:background="#0E1320"
        android:visibility="visible">

        <LinearLayout
            android:id="@+id/history_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp"/>
    </ScrollView>

    <!-- Volume -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="4dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔊"
            android:textSize="16sp"
            android:layout_marginEnd="8dp"/>

        <SeekBar
            android:id="@+id/seekbar_volume"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="100"
            android:progress="80"/>
    </LinearLayout>

    <!-- Status -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="4dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_mic_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="●"
            android:textColor="#666666"
            android:textSize="10sp"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Ouvindo"
            android:textColor="#888888"
            android:textSize="12sp"/>

        <Button
            android:id="@+id/btn_save_pdf"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="📄 PDF"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1E3A2F"
            android:paddingHorizontal="8dp"/>
    </LinearLayout>

    <!-- Botão Gemini -->
    <Button
        android:id="@+id/btn_gemini"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginHorizontal="8dp"
        android:layout_marginBottom="4dp"
        android:text="🤖 Gemini OFF"
        android:textSize="13sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#333333"/>

    <!-- Botão principal -->
    <Button
        android:id="@+id/btn_listen"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="8dp"
        android:layout_marginBottom="8dp"
        android:text="▶ Iniciar Conversa"
        android:textSize="15sp"
        android:textStyle="bold"
        android:backgroundTint="#3D5AFE"
        android:textColor="#FFFFFF"/>

</LinearLayout>
